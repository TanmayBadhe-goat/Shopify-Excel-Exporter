# ── Shopify API Credentials ────────────────────────────────────────────────
# Your Shopify store name (e.g., "mystore.myshopify.com")
SHOPIFY_SHOP=

# OAuth App credentials (create at https:// partners.shopify.com / your-app)
# Required scopes: read_orders, read_products
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# API version (default: 2024-04)
# API_VERSION=2024-04
